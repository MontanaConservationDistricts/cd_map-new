.popup {
  display: flex;
  gap: 10px;
  max-width: 260px;
  font-size: 13px;
  line-height: 1.4;
}

.popup-left {
  flex: 0 0 70px;
}

.popup-left img {
  width: 70px;
  height: auto;
  border-radius: 4px;
  object-fit: contain;
}

.popup-right {
  flex: 1;
}

.popup-right h3 {
  margin: 0 0 4px;
  font-size: 15px;
  color: #1f4e79;
}

.popup-right div {
  margin-bottom: 2px;
}

.popup a {
  color: #1f4e79;
  text-decoration: none;
}
