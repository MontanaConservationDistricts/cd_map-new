.popup {
  display: flex;
  gap: 10px;
  max-width: 260px;
  font-size: 13px;
  line-height: 1.4;
  align-items: flex-start;
}

.popup-left {
  flex: 0 0 70px;
  display: none; /* hide by default */
}

.popup-left img {
  width: 70px;
  height: auto;
  border-radius: 4px;
  object-fit: contain;
}

.popup-right {
  flex: 1;
}

.popup-left img:only-child {
  display: block;
}
