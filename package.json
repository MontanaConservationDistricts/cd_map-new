<script>
const map = L.map('map');

// Base map
L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
  attribution: '&copy; OpenStreetMap contributors'
}).addTo(map);

// FILES
const districtsUrl = "data/district-boundaries_simplified-disable.geojson";
const backgroundUrl = "data/MT_background.geojson";
const csvUrl = "https://docs.google.com/spreadsheets/d/e/2PACX-1vQOhw-AhzNOE7w-1Fc82Lxew_OVewMp-wz3aMLF137YZWDegmqtMh1QtrExCVyjl2_73LNTzqSVRG_Y/pub?output=csv&gid=203628658";

// Load everything
Promise.all([
  fetch(districtsUrl).then(r => r.json()),
  fetch(backgroundUrl).then(r => r.json()),
  fetch(csvUrl).then(r => r.text())
]).then(([districts, background, csvText]) => {

  const csv = Papa.parse(csvText, { header: true }).data;

  // Build lookup using MACD_NAME
  const lookup = {};
  csv.forEach(row => {
    if (row.MACD_NAME) {
      lookup[row.MACD_NAME.trim().toLowerCase()] = row;
    }
  });

  // Background (light gray Montana)
  const bgLayer = L.geoJSON(background, {
    style: {
      color: "#cccccc",
      weight: 1,
      fillColor: "#eeeeee",
      fillOpacity: 1
    }
  }).addTo(map);

  // Districts layer (interactive)
  const districtLayer = L.geoJSON(districts, {

    style: {
      color: "#ffffff",
      weight: 1,
      fillColor: "#2c6da4",
      fillOpacity: 0.6
    },

    onEachFeature: function(feature, layer) {

      const key = feature.properties.MACD_NAME?.trim().toLowerCase();
      const row = lookup[key];

      if (row) {

        const popup = `
          <div class="popup">
            <div class="popup-left">
              <img src="${row.cd_logo || 'https://via.placeholder.com/70'}">
            </div>
            <div class="popup-right">
              <h3>${row.MACD_NAME}</h3>

              ${row.physical_address ? `<div>${row.physical_address}</div>` : ""}
              ${row.Phone ? `<div><strong>P:</strong> ${row.Phone}</div>` : ""}
              ${row.Email ? `<div><strong>E:</strong> ${row.Email}</div>` : ""}
              ${row.Hours ? `<div><strong>H:</strong> ${row.Hours}</div>` : ""}

              ${row.Website ? `<div><a href="${row.Website}" target="_blank">Website</a></div>` : ""}
              ${row.social_media ? `<div><a href="${row.social_media}" target="_blank">Social</a></div>` : ""}
            </div>
          </div>
        `;

        layer.bindPopup(popup);
      }

      // Hover behavior (matches MACD feel)
      layer.on({
        mouseover: e => {
          e.target.setStyle({
            fillOpacity: 0.85
          });
        },
        mouseout: e => {
          e.target.setStyle({
            fillOpacity: 0.6
          });
        }
      });

    }

  }).addTo(map);

  // Fit map perfectly to Montana
  map.fitBounds(districtLayer.getBounds());

});
</script>
